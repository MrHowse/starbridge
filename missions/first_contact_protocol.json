{
  "id": "first_contact_protocol",
  "name": "First Contact Protocol",
  "briefing": "An unknown vessel has entered sensor range on an unusual frequency. Science: begin long-range analysis. Comms: monitor all channels and prepare to decode any transmissions. The nature of this contact is unknown.",
  "nodes": [
    {
      "id": "obj_signal",
      "type": "objective",
      "text": "Intercept alien transmissions",
      "trigger": {
        "type": "timer_elapsed",
        "seconds": 5
      }
    },
    {
      "id": "parallel_comms",
      "type": "parallel",
      "text": "Complete science and comms analysis",
      "complete_when": "all",
      "children": [
        {
          "id": "obj_freq",
          "type": "objective",
          "text": "Lock on to the alien frequency",
          "trigger": {
            "type": "puzzle_resolved",
            "label": "alien_freq"
          }
        },
        {
          "id": "obj_decode",
          "type": "objective",
          "text": "Decode the alien transmission",
          "trigger": {
            "type": "puzzle_resolved",
            "label": "alien_transmission"
          }
        }
      ]
    },
    {
      "id": "obj_contact",
      "type": "objective",
