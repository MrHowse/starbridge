          "label": "alien_freq",
          "difficulty": 2,
          "time_limit": 90.0
        },
        {
          "action": "start_puzzle",
          "puzzle_type": "transmission_decoding",
          "station": "comms",
          "label": "alien_transmission",
          "difficulty": 2,
          "time_limit": 90.0
        }
      ]
    },
    {
      "from": "parallel_comms",
      "to": "obj_contact",
      "type": "sequence"
    }
  ],
  "start_node": "obj_signal",
  "victory_nodes": [
    "obj_contact"
  ],
  "defeat_condition": {
    "type": "player_hull_zero"
